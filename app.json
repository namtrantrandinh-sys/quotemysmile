{
  "expo": {
    "name": "QuoteMySmile",
    "slug": "quotemysmile",
    "scheme": "qms",
    "version": "0.0.1",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "376c8cbe-b615-415f-9f86-a60b7eac39db"
      }
    },
    "owner": "lordly",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.quotemysmile.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "QuoteMySmile uses your location to find dentists nearby. We never track in the background and never sell your location.",
        "NSLocationAccuracyAuthorizationDescription": "Precise location is used to match you with the closest dentists.",
        "NSCameraUsageDescription": "QuoteMySmile uses your camera to capture guided photos of your teeth for accurate quotes.",
        "NSMicrophoneUsageDescription": "QuoteMySmile uses your microphone only when you choose to record a short video clip of your teeth instead of a photo.",
        "NSPhotoLibraryAddUsageDescription": "Save your dental quotes and consult details to your photo library.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.quotemysmile.app",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "CAMERA",
        "RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "CAMERA",
        "RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "REPLACE_WITH_ANDROID_GOOGLE_MAPS_KEY"
        }
      }
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#F5F1E8",
          "image": "./assets/splash.png",
          "imageWidth": 200
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "QuoteMySmile uses your location to find dentists nearby. We never track in the background and never sell location data."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "QuoteMySmile uses your camera to capture guided photos of your teeth for accurate quotes.",
          "microphonePermission": "QuoteMySmile uses your microphone only when you choose to record a short video clip instead of a photo.",
          "recordAudioAndroid": true
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "16.4",
            "useFrameworks": "static",
            "privacyManifestPath": "./store/PrivacyInfo.xcprivacy"
          },
          "android": {
            "minSdkVersion": 24,
            "compileSdkVersion": 34,
            "targetSdkVersion": 34
          }
        }
      ],
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "merchant.com.quotemysmile.app",
          "enableGooglePay": true
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#A9CFC0",
          "defaultChannel": "default"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": false
    },
    "updates": {
      "url": "https://u.expo.dev/376c8cbe-b615-415f-9f86-a60b7eac39db"
    }
  }
}
