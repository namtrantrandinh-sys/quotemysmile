# Copy to .env.local and fill in.
# Publishable keys are SAFE in client code (RLS protects data).
# Secret/service_role keys MUST stay server-only — never expose in app code.

EXPO_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_<your_key_here>

# Optional — Sentry. App runs fine without; install + DSN unlocks error reporting.
# Create a NEW project specifically for QuoteMySmile.
# EXPO_PUBLIC_SENTRY_DSN=https://<key>@<org>.ingest.sentry.io/<project>
